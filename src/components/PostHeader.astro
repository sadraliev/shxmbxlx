---
import { ReaderControls } from "./ReaderControls";
import { formatDate } from "../lib/date";

interface Props {
  kind: "Essay" | "Note";
  title: string;
  date: Date;
  updated?: Date;
}

const { kind, title, date, updated } = Astro.props;
---

<header class="mb-8">
  <div class="flex items-center justify-between gap-4">
    <p class="uppercase tracking-widest text-xs text-muted-foreground m-0">
      {kind}
    </p>
    <ReaderControls client:load />
  </div>
  <h1 class="mt-2 mb-2 text-[2rem] leading-tight">{title}</h1>
  <p class="text-muted-foreground text-[0.85rem] m-0">
    <time datetime={date.toISOString()}>{formatDate(date, "long")}</time>
    {updated && <span>· updated {formatDate(updated, "long")}</span>}
  </p>
</header>
