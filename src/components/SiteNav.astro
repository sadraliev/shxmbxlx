---
const pathname = Astro.url.pathname;
const isEssays = pathname === "/essays" || pathname.startsWith("/essays/");
const isNotes = pathname === "/notes" || pathname.startsWith("/notes/");
---

<nav
  class="container py-4 flex flex-wrap items-center text-[0.95rem]"
  aria-label="Categories"
>
  <a
    href="/essays"
    class:list={[
      "underline decoration-border underline-offset-[3px] decoration-1 hover:text-primary hover:decoration-current",
      isEssays ? "text-foreground font-medium" : "text-muted-foreground",
    ]}>essays</a
  >
  <span class="text-muted-foreground opacity-50 px-2" aria-hidden="true">·</span
  >
  <a
    href="/notes"
    class:list={[
      "underline decoration-border underline-offset-[3px] decoration-1 hover:text-primary hover:decoration-current",
      isNotes ? "text-foreground font-medium" : "text-muted-foreground",
    ]}>notes</a
  >
</nav>
