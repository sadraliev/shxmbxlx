---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<BaseLayout title="Essays — shxmbxlx" description="Essays and longer-form notes.">
  <article class="prose">
    <h1>Essays</h1>
    <p>Essays and longer-form notes.</p>

    {essays.length === 0 ? (
      <p><em>No essays yet.</em></p>
    ) : (
      <ul class="post-list">
        {essays.map((entry) => (
          <li>
            <a href={`/essays/${entry.id}`}>
              <span class="post-title">{entry.data.title}</span>
              <time datetime={entry.data.date.toISOString()}>{dateFmt(entry.data.date)}</time>
            </a>
            {entry.data.description && (
              <p class="post-desc">{entry.data.description}</p>
            )}
          </li>
        ))}
      </ul>
    )}
  </article>
</BaseLayout>

<style>
  .post-list {
    list-style: none;
    margin: 1.5rem 0;
    padding: 0;
  }
  .post-list li {
    border-bottom: 1px solid var(--border);
    padding: 0.85rem 0;
  }
  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    color: var(--foreground);
  }
  .post-list a:hover {
    color: var(--primary);
    text-decoration: none;
  }
  .post-title {
    flex: 1;
    font-weight: 500;
  }
  .post-list time {
    color: var(--muted-foreground);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .post-desc {
    color: var(--muted-foreground);
    font-size: 0.95rem;
    margin: 0.25rem 0 0;
  }
</style>
