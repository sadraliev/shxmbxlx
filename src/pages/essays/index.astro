---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<BaseLayout title="Essays — shxmbxlx" description='"Que sais-je?" — Montaigne'>
  <article class="prose">
    <h1>Essays</h1>

    <blockquote
      class="bg-transparent border-l-2 border-border rounded-none py-1 px-4 my-5 mb-10 text-muted-foreground"
    >
      <p class="m-0 leading-normal font-serif italic text-foreground">
        &ldquo;Que sais-je?&rdquo;
      </p>
      <p
        class="m-0 mt-1 leading-normal text-[0.85rem] text-muted-foreground tabular-nums"
      >
        &mdash; Montaigne
      </p>
    </blockquote>

    {
      essays.length === 0 ? (
        <p class="text-muted-foreground">
          <em>Nothing here yet.</em>
        </p>
      ) : (
        <ul class="list-none m-0 my-6 p-0">
          {essays.map((entry) => (
            <li class="border-b border-border py-[0.85rem]">
              <a
                href={`/essays/${entry.id}`}
                class="flex justify-between items-baseline gap-4 text-foreground hover:text-primary hover:no-underline"
              >
                <span class="flex-1 font-medium">{entry.data.title}</span>
                <time
                  datetime={entry.data.date.toISOString()}
                  class="text-muted-foreground text-[0.85rem] tabular-nums whitespace-nowrap"
                >
                  {dateFmt(entry.data.date)}
                </time>
              </a>
              {entry.data.description && (
                <p class="text-muted-foreground text-[0.95rem] mt-1 mb-0">
                  {entry.data.description}
                </p>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </article>
</BaseLayout>
