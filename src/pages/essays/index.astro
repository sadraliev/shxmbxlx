---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<BaseLayout title="Essays — shxmbxlx" description='"Que sais-je?" — Montaigne'>
  <article class="prose">
    <h1>Essays</h1>

    <blockquote class="epigraph">
      <p class="fr">&ldquo;Que sais-je?&rdquo;</p>
      <p class="cite">&mdash; Montaigne</p>
    </blockquote>

    {essays.length === 0 ? (
      <p class="empty"><em>Nothing here yet.</em></p>
    ) : (
      <ul class="post-list">
        {essays.map((entry) => (
          <li>
            <a href={`/essays/${entry.id}`}>
              <span class="post-title">{entry.data.title}</span>
              <time datetime={entry.data.date.toISOString()}>{dateFmt(entry.data.date)}</time>
            </a>
            {entry.data.description && (
              <p class="post-desc">{entry.data.description}</p>
            )}
          </li>
        ))}
      </ul>
    )}
  </article>
</BaseLayout>

<style>
  /* Epigraph — quieter than a normal blockquote. Override .prose defaults. */
  .prose .epigraph {
    background: transparent;
    border-left: 2px solid var(--border);
    padding: 0.25rem 1rem;
    margin: 1.25rem 0 2.5rem;
    border-radius: 0;
    color: var(--muted-foreground);
  }
  .epigraph p {
    margin: 0;
    line-height: 1.5;
  }
  .fr {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--foreground);
  }
  .cite {
    margin-top: 0.25rem !important;
    font-size: 0.85rem;
    color: var(--muted-foreground);
    font-variant-numeric: tabular-nums;
  }

  .empty {
    color: var(--muted-foreground);
  }

  .post-list {
    list-style: none;
    margin: 1.5rem 0;
    padding: 0;
  }
  .post-list li {
    border-bottom: 1px solid var(--border);
    padding: 0.85rem 0;
  }
  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    color: var(--foreground);
  }
  .post-list a:hover {
    color: var(--primary);
    text-decoration: none;
  }
  .post-title {
    flex: 1;
    font-weight: 500;
  }
  .post-list time {
    color: var(--muted-foreground);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .post-desc {
    color: var(--muted-foreground);
    font-size: 0.95rem;
    margin: 0.25rem 0 0;
  }
</style>
