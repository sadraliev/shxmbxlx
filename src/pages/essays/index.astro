---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((entry) => ({
    href: `/essays/${entry.id}`,
    title: entry.data.title,
    description: entry.data.description,
    date: entry.data.date,
  }));
---

<BaseLayout title="Essays — shxmbxlx" description='"Que sais-je?" — Montaigne'>
  <article class="prose">
    <h1>Essays</h1>

    <blockquote
      class="bg-transparent border-l-2 border-border rounded-none py-1 px-4 my-5 mb-10 text-muted-foreground"
    >
      <p class="m-0 leading-normal font-serif italic text-foreground">
        &ldquo;Que sais-je?&rdquo;
      </p>
      <p
        class="m-0 mt-1 leading-normal text-[0.85rem] text-muted-foreground tabular-nums"
      >
        &mdash; Montaigne
      </p>
    </blockquote>

    <PostList items={essays} emptyMessage="Nothing here yet." />
  </article>
</BaseLayout>
