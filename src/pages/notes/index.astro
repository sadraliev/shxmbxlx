---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const notes = (await getCollection("notes", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<BaseLayout
  title="Notes — shxmbxlx"
  description="Notes on building, learning, and turning ideas into value."
>
  <article class="prose">
    <h1>Notes</h1>
    <p><em>Notes on building, learning, and turning ideas into value.</em></p>

    {
      notes.length === 0 ? (
        <p>
          <em>No notes yet.</em>
        </p>
      ) : (
        <ul class="list-none m-0 my-6 p-0">
          {notes.map((entry) => (
            <li class="border-b border-border last:border-b-0 py-4">
              <a
                href={`/notes/${entry.id}`}
                class="flex justify-between items-baseline gap-4 text-foreground hover:text-primary hover:no-underline max-[520px]:flex-col max-[520px]:gap-1"
              >
                <span class="flex-1 font-medium">{entry.data.title}</span>
                <time
                  datetime={entry.data.date.toISOString()}
                  class="text-muted-foreground text-[0.85rem] tabular-nums whitespace-nowrap"
                >
                  {dateFmt(entry.data.date)}
                </time>
              </a>
              {entry.data.description && (
                <p class="text-muted-foreground text-[0.95rem] leading-[1.55] mt-[0.4rem] mb-0">
                  {entry.data.description}
                </p>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </article>
</BaseLayout>
