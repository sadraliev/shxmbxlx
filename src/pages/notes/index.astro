---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const notes = (await getCollection("notes", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<BaseLayout title="Notes — shxmbxlx" description="Notes on building, learning, and turning ideas into value.">
  <article class="prose">
    <h1>Notes</h1>
    <p><em>Notes on building, learning, and turning ideas into value.</em></p>

    {notes.length === 0 ? (
      <p><em>No notes yet.</em></p>
    ) : (
      <ul class="post-list">
        {notes.map((entry) => (
          <li>
            <a href={`/notes/${entry.id}`} class="post-link">
              <span class="post-title">{entry.data.title}</span>
              <time datetime={entry.data.date.toISOString()}>{dateFmt(entry.data.date)}</time>
            </a>
            {entry.data.description && (
              <p class="post-desc">{entry.data.description}</p>
            )}
          </li>
        ))}
      </ul>
    )}
  </article>
</BaseLayout>

<style>
  .post-list {
    list-style: none;
    margin: 1.5rem 0;
    padding: 0;
  }
  .post-list li {
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
  }
  .post-list li:last-child {
    border-bottom: none;
  }
  .post-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    color: var(--foreground);
  }
  .post-link:hover {
    color: var(--primary);
    text-decoration: none;
  }
  .post-title {
    flex: 1;
    font-weight: 500;
  }
  .post-list time {
    color: var(--muted-foreground);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .post-desc {
    color: var(--muted-foreground);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0.4rem 0 0;
  }

  @media (max-width: 520px) {
    .post-link {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
