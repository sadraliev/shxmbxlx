---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ReaderControls } from "../../components/ReaderControls";

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );
  return notes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<BaseLayout
  title={`${entry.data.title} — shxmbxlx`}
  description={entry.data.description}
>
  <article class="prose">
    <header class="mb-8">
      <div class="flex items-center justify-between gap-4">
        <p
          class="uppercase tracking-widest text-xs text-muted-foreground m-0"
        >
          Note
        </p>
        <ReaderControls client:load />
      </div>
      <h1 class="mt-2 mb-2 text-[2rem] leading-tight">{entry.data.title}</h1>
      <p class="text-muted-foreground text-[0.85rem] m-0">
        <time datetime={entry.data.date.toISOString()}
          >{dateFmt(entry.data.date)}</time
        >
      </p>
    </header>
    <Content />
  </article>
</BaseLayout>
