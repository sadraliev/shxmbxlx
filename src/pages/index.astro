---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft)).map(
  (entry) => ({
    kind: "essay" as const,
    href: `/essays/${entry.id}`,
    title: entry.data.title,
    description: entry.data.description,
    date: entry.data.date,
  }),
);

const notes = (await getCollection("notes", ({ data }) => !data.draft)).map(
  (entry) => ({
    kind: "note" as const,
    href: `/notes/${entry.id}`,
    title: entry.data.title,
    description: entry.data.description,
    date: entry.data.date,
  }),
);

const latest = [...essays, ...notes]
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 10);

const draftEssays = (
  await getCollection("essays", ({ data }) => data.draft)
).map((entry) => ({
  kind: "essay" as const,
  title: entry.data.title,
  description: entry.data.description,
  date: entry.data.date,
}));

const draftNotes = (await getCollection("notes", ({ data }) => data.draft)).map(
  (entry) => ({
    kind: "note" as const,
    title: entry.data.title,
    description: entry.data.description,
    date: entry.data.date,
  }),
);

const comingUp = [...draftEssays, ...draftNotes]
  .sort((a, b) => a.date.getTime() - b.date.getTime())
  .map(({ date, ...rest }) => rest);
---

<BaseLayout title="shxmbxlx">
  <section>
    <section class="mb-12">
      <p class="text-[1.15rem] mt-0 mb-2 text-foreground">
        Hi, I'm <strong class="text-foreground font-semibold">Aibek</strong>.
      </p>
      <p class="text-muted-foreground m-0 text-base leading-[1.65]">
        I build web apps and the infrastructure they live on. I write here about
        what I'm learning, what I'm breaking, and what I'm shipping &mdash; in
        public, slowly, on purpose.
      </p>
      <p class="mt-4 mb-0 text-[0.95rem]">
        <a
          href="https://github.com/sadraliev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground underline decoration-border decoration-1 underline-offset-[3px] hover:text-primary hover:decoration-current"
          >GitHub</a
        >
        <span class="text-muted-foreground opacity-50 px-2" aria-hidden="true"
          >·</span
        >
        <a
          href="https://www.linkedin.com/in/sadraliev/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground underline decoration-border decoration-1 underline-offset-[3px] hover:text-primary hover:decoration-current"
          >LinkedIn</a
        >
        <span class="text-muted-foreground opacity-50 px-2" aria-hidden="true"
          >·</span
        >
        <a
          href="mailto:a.sadraliev@gmail.com"
          class="text-muted-foreground underline decoration-border decoration-1 underline-offset-[3px] hover:text-primary hover:decoration-current"
          >Email</a
        >
      </p>
    </section>

    <section class="mt-8">
      <header class="border-b border-border pb-2 mb-2">
        <h2
          class="m-0 text-[0.8rem] uppercase tracking-[0.12em] text-muted-foreground font-semibold"
        >
          Latest
        </h2>
      </header>
      <PostList items={latest} emptyMessage="No posts yet." />
    </section>

    {
      comingUp.length > 0 && (
        <section class="mt-8">
          <header class="border-b border-border pb-2 mb-2">
            <h2 class="m-0 text-[0.8rem] uppercase tracking-[0.12em] text-muted-foreground font-semibold">
              Coming up
            </h2>
          </header>
          <PostList items={comingUp} />
        </section>
      )
    }
  </section>
</BaseLayout>
