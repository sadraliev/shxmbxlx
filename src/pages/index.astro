---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft)).map(
  (entry) => ({
    kind: "essay" as const,
    url: `/essays/${entry.id}`,
    title: entry.data.title,
    description: entry.data.description,
    date: entry.data.date,
  }),
);

const notes = (await getCollection("notes", ({ data }) => !data.draft)).map(
  (entry) => ({
    kind: "note" as const,
    url: `/notes/${entry.id}`,
    title: entry.data.title,
    description: entry.data.description,
    date: entry.data.date,
  }),
);

const latest = [...essays, ...notes].sort(
  (a, b) => b.date.getTime() - a.date.getTime(),
);

const draftEssays = (
  await getCollection("essays", ({ data }) => data.draft)
).map((entry) => ({
  kind: "essay" as const,
  title: entry.data.title,
  description: entry.data.description,
  date: entry.data.date,
}));

const draftNotes = (await getCollection("notes", ({ data }) => data.draft)).map(
  (entry) => ({
    kind: "note" as const,
    title: entry.data.title,
    description: entry.data.description,
    date: entry.data.date,
  }),
);

const comingUp = [...draftEssays, ...draftNotes].sort(
  (a, b) => a.date.getTime() - b.date.getTime(),
);

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<BaseLayout title="shxmbxlx">
  <section>
    <section class="mb-12">
      <p class="text-[1.15rem] mt-0 mb-2 text-foreground">
        Hi, I'm <strong class="text-foreground font-semibold">Aibek</strong>.
      </p>
      <p class="text-muted-foreground m-0 text-base leading-[1.65]">
        I build web apps and the infrastructure they live on. I write here about
        what I'm learning, what I'm breaking, and what I'm shipping &mdash; in
        public, slowly, on purpose.
      </p>
      <p class="mt-4 mb-0 text-[0.95rem]">
        <a
          href="https://github.com/sadraliev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground underline decoration-border decoration-1 underline-offset-[3px] hover:text-primary hover:decoration-current"
          >GitHub</a
        >
        <span class="text-muted-foreground opacity-50 px-2" aria-hidden="true"
          >·</span
        >
        <a
          href="https://www.linkedin.com/in/sadraliev/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground underline decoration-border decoration-1 underline-offset-[3px] hover:text-primary hover:decoration-current"
          >LinkedIn</a
        >
        <span class="text-muted-foreground opacity-50 px-2" aria-hidden="true"
          >·</span
        >
        <a
          href="mailto:a.sadraliev@gmail.com"
          class="text-muted-foreground underline decoration-border decoration-1 underline-offset-[3px] hover:text-primary hover:decoration-current"
          >Email</a
        >
      </p>
    </section>

    <section class="mt-8">
      <header class="border-b border-border pb-2 mb-2">
        <h2
          class="m-0 text-[0.8rem] uppercase tracking-[0.12em] text-muted-foreground font-semibold"
        >
          Latest
        </h2>
      </header>

      {
        latest.length === 0 ? (
          <p class="text-muted-foreground italic py-2">No posts yet.</p>
        ) : (
          <ul class="list-none m-0 p-0">
            {latest.slice(0, 10).map((post) => (
              <li class="border-b border-border last:border-b-0 py-4">
                <a
                  href={post.url}
                  class="grid grid-cols-[auto_1fr_auto] items-baseline gap-x-[0.85rem] text-foreground hover:text-primary hover:no-underline max-[520px]:grid-cols-[auto_1fr] max-[520px]:gap-y-1 group"
                >
                  <span class="font-mono text-[0.7rem] uppercase tracking-[0.1em] text-muted-foreground py-[0.15rem] px-[0.45rem] border border-border rounded self-center leading-[1.2] group-hover:text-muted-foreground">
                    {post.kind}
                  </span>
                  <span class="font-medium">{post.title}</span>
                  <time
                    datetime={post.date.toISOString()}
                    class="text-muted-foreground text-[0.85rem] tabular-nums whitespace-nowrap max-[520px]:col-start-2"
                  >
                    {dateFmt(post.date)}
                  </time>
                </a>
                {post.description && (
                  <p class="text-muted-foreground text-[0.95rem] mt-[0.35rem] mb-0 pl-[calc(0.45rem+0.85rem+4ch)] max-[520px]:pl-0">
                    {post.description}
                  </p>
                )}
              </li>
            ))}
          </ul>
        )
      }
    </section>

    {
      comingUp.length > 0 && (
        <section class="mt-8">
          <header class="border-b border-border pb-2 mb-2">
            <h2 class="m-0 text-[0.8rem] uppercase tracking-[0.12em] text-muted-foreground font-semibold">
              Coming up
            </h2>
          </header>
          <ul class="list-none m-0 p-0">
            {comingUp.map((post) => (
              <li class="border-b border-border last:border-b-0 py-4">
                <div class="grid grid-cols-[auto_1fr_auto] items-baseline gap-x-[0.85rem] text-muted-foreground">
                  <span class="font-mono text-[0.7rem] uppercase tracking-[0.1em] text-muted-foreground py-[0.15rem] px-[0.45rem] border border-border rounded self-center leading-[1.2]">
                    {post.kind}
                  </span>
                  <span class="font-medium">{post.title}</span>
                </div>
                {post.description && (
                  <p class="text-muted-foreground text-[0.95rem] mt-[0.35rem] mb-0 pl-[calc(0.45rem+0.85rem+4ch)] max-[520px]:pl-0">
                    {post.description}
                  </p>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </section>
</BaseLayout>
