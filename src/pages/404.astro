---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — shxmbxlx" description="Page not found.">
  <section class="max-w-[540px] mx-auto mt-16 text-left">
    <p
      class="font-mono text-[0.85rem] text-muted-foreground tracking-[0.4em] mt-0 mb-6"
    >
      4 0 4
    </p>

    <h1
      class="font-mono font-semibold text-[clamp(2rem,6vw,3rem)] leading-tight m-0 mb-6 tracking-tight text-foreground"
    >
      <span class="text-foreground">P</span><span class="fade">a</span><span
        class="text-foreground">g</span
      ><span class="fade">e</span>
      <span class="text-foreground">n</span><span class="fade">o</span><span
        class="text-foreground">t</span
      >
      <span class="text-foreground">f</span><span class="fade">o</span><span
        class="text-foreground">u</span
      ><span class="fade">n</span><span class="text-foreground">d</span>
    </h1>

    <p class="text-muted-foreground text-[1.05rem] mt-0 mb-8">
      The vowels are still here. The page isn't.
    </p>

    <nav class="flex gap-6 mb-16">
      <a
        href="/"
        class="font-mono text-foreground text-[0.95rem] no-underline hover:text-primary"
        >→ home</a
      >
      <a
        href="/notes"
        class="font-mono text-foreground text-[0.95rem] no-underline hover:text-primary"
        >→ notes</a
      >
    </nav>

    <p
      class="text-muted-foreground text-[0.85rem] border-t border-border pt-4 m-0"
    >
      <code
        class="font-mono bg-muted px-[0.4em] py-[0.1em] rounded text-[0.9em]"
        >shxmbxlx</code
      > &mdash; even the wordmark loses its vowels around here.
    </p>
  </section>
</BaseLayout>

<style>
  /* Vowels fade in and out gently — they don't really belong here. */
  .fade {
    color: var(--muted-foreground);
    animation: fade 4s ease-in-out infinite;
  }
  .fade:nth-child(even) {
    animation-delay: 0.5s;
  }
  .fade:nth-child(3n) {
    animation-delay: 1s;
  }

  @keyframes fade {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.2;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fade {
      animation: none;
      opacity: 0.5;
    }
  }
</style>
