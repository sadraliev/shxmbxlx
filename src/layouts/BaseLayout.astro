---
import "../styles/globals.css";
import { ClientRouter } from "astro:transitions";
import Logo from "../components/Logo.astro";
import { ThemeToggle } from "../components/ThemeToggle";
import { LangFilter } from "../components/LangFilter";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: "en" | "ru" | "ky";
}

const {
  title,
  description = "Notes on building, learning, and turning ideas into value.",
  ogImage = "/og-image.png",
  lang = "en",
} = Astro.props;

const pathname = Astro.url.pathname;
const isEssays = pathname === "/essays" || pathname.startsWith("/essays/");
const isNotes = pathname === "/notes" || pathname.startsWith("/notes/");
const isHome = pathname === "/" || pathname === "";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="shxmbxlx" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const pref = stored === "light" || stored === "dark" ? stored : "auto";
        const isDark =
          pref === "dark" ||
          (pref === "auto" && window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.classList.toggle("dark", isDark);
        document.documentElement.setAttribute("data-theme-pref", pref);
      })();
    </script>
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("lang-filter");
        const pref = stored === "en" || stored === "ru" || stored === "ky" ? stored : "en";
        document.documentElement.setAttribute("data-lang-filter", pref);
      })();
    </script>
    <ClientRouter />
    <script is:inline>
      (() => {
        const ua = navigator.userAgent;
        const isSafari = /^((?!chrome|android|crios|fxios|edg).)*safari/i.test(ua);
        if (isSafari) {
          document.addEventListener("astro:before-preparation", (e) => {
            e.preventDefault();
          });
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <Logo />
        <div class="site-header__actions">
          <LangFilter client:load />
          <ThemeToggle client:load />
        </div>
      </div>
    </header>

    <div class="shell">
      <aside class="sidebar">
        <nav class="sidebar-nav" aria-label="Categories">
          <ul>
            <li>
              <a href="/" class:list={["sidebar-link", { active: isHome }]}>home</a>
            </li>
            <li>
              <a href="/essays" class:list={["sidebar-link", { active: isEssays }]}>essays</a>
            </li>
            <li>
              <a href="/notes" class:list={["sidebar-link", { active: isNotes }]}>notes</a>
            </li>
          </ul>
        </nav>
      </aside>

      <main>
        <slot />
      </main>
    </div>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <span>&copy; {new Date().getFullYear()} shxmbxlx</span>
      </div>
    </footer>
  </body>
</html>
